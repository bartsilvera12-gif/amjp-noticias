# Configuración del servidor AMJP — copiar a ".env" y completar.
# El archivo .env NO se versiona (está en .gitignore).

# Secreto de sesión (cambiar por un valor largo y aleatorio en producción)
SESSION_SECRET=cambiar-esto-por-un-valor-largo-y-aleatorio

# URL pública del sitio (se usa en los enlaces de los correos)
SITE_URL=http://localhost:5173

# ---- Envío de correos (SMTP) ----
# Datos del servidor de correo de la AMJP (o un proveedor: Gmail, Zoho, SendGrid, etc.).
# Si se dejan vacíos, el sitio funciona igual pero NO envía correos (solo lo registra en consola).
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
# Remitente que verá el destinatario, p. ej.: AMJP <info@amjp.org.py>
MAIL_FROM=
