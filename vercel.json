{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "redirects": [
    { "source": "/", "destination": "/amjp/", "permanent": false },
    { "source": "/admin", "destination": "/amjp/admin/", "permanent": false }
  ],
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/index" }
  ]
}
